{
  "$schema": "https://turborepo.com/schema.json",
  "globalPassThroughEnv": [
    "DATABASE_URL",
    "STORE_API_URL",
    "VITE_API_URL",
    "AI_GATEWAY_API_KEY",
    "BETTER_AUTH_SECRET"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "dist-electron/**", "release/**"]
    },
    "check": {
      "dependsOn": ["^check"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "preview": {
      "cache": false,
      "persistent": true
    }
  }
}
