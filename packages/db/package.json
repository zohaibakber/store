{
  "name": "@store/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./auth.database": "./src/remote/auth.database.ts",
    "./auth.schema": "./src/remote/auth.schema.ts",
    "./local/relations": "./src/local/relations.ts",
    "./local/schema": "./src/local/schema.ts",
    "./remote/relations": "./src/remote/relations.ts",
    "./remote/schema": "./src/remote/schema.ts",
    "./store.schema": "./src/shared/store.schema.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "check": "tsc --noEmit && node scripts/drizzle-kit.cjs check --config drizzle.local.config.ts && node scripts/drizzle-kit.cjs check --config drizzle.remote.config.ts",
    "db:generate": "node scripts/drizzle-kit.cjs generate --config drizzle.local.config.ts && node scripts/drizzle-kit.cjs generate --config drizzle.remote.config.ts",
    "db:migrate": "node scripts/drizzle-kit.cjs migrate --config drizzle.remote.config.ts"
  },
  "dependencies": {
    "drizzle-orm": "1.0.0-rc.4",
    "kysely": "^0.29.3",
    "nanoid": "^5.1.16",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.13",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "1.0.0-rc.4",
    "typescript": "catalog:"
  }
}
