{
  "name": "@store/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./auth.database": "./src/auth.database.ts",
    "./auth.schema": "./src/auth.schema.ts",
    "./relations": "./src/relations.ts",
    "./schema": "./src/schema.ts",
    "./store.schema": "./src/store.schema.ts",
    "./sync.schema": "./src/sync.schema.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "check": "tsc --noEmit && node scripts/drizzle-kit.cjs check",
    "db:generate": "node scripts/drizzle-kit.cjs generate",
    "db:migrate": "node scripts/drizzle-kit.cjs migrate"
  },
  "dependencies": {
    "drizzle-orm": "1.0.0-rc.4",
    "kysely": "^0.29.3",
    "nanoid": "^5.1.16",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.13",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "1.0.0-rc.4",
    "typescript": "^7.0.2"
  }
}
