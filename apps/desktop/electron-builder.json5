// @see - https://www.electron.build/configuration/configuration
{
  $schema: "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  appId: "com.tabaaq.desktop",
  executableName: "store-electron",
  asar: true,
  asarUnpack: ["**/*.node", "**/*.wasm", "**/*.data"],
  // Fail before signing or publishing if monorepo/server sources, credentials,
  // or database schema code cross into the packaged desktop boundaries.
  afterPack: "./scripts/verify-after-pack.cjs",
  productName: "Tabaaq",
  protocols: [
    {
      name: "Tabaaq",
      schemes: ["com.tabaaq.desktop"],
    },
  ],
  directories: {
    output: "release/${version}",
  },
  // The source repo is public, so releases and auto-update checks are
  // published directly here rather than to a separate releases-only repo.
  publish: [
    {
      provider: "github",
      owner: "zohaibakber",
      repo: "store",
      releaseType: "release",
    },
  ],
  files: ["dist", "dist-electron"],
  icon: "public/logo.png",
  extraResources: [
    {
      from: "../../packages/db/migrations/local",
      to: "database-migrations",
    },
    {
      // BrowserWindow's `icon` option loads through nativeImage, which reads
      // the real filesystem and can't see into app.asar — so the icon must
      // live outside the archive to show up at runtime in production.
      from: "public/logo.png",
      to: "logo.png",
    },
  ],
  mac: {
    target: ["dmg"],
    artifactName: "${productName}-Mac-${version}-Installer.${ext}",
  },
  win: {
    target: [
      {
        target: "nsis",
        arch: ["x64"],
      },
    ],
    artifactName: "${productName}-Windows-${version}-Setup.${ext}",
  },
  nsis: {
    oneClick: false,
    perMachine: false,
    allowToChangeInstallationDirectory: true,
    deleteAppDataOnUninstall: false,
  },
  linux: {
    target: ["AppImage"],
    artifactName: "${productName}-Linux-${version}.${ext}",
    category: "Office",
    maintainer: "Zohaib Akber <zohaibakber99@gmail.com>",
    // electron-builder's icon converter copies a single source PNG as-is
    // instead of generating the standard hicolor size ladder, so the
    // launcher/app-search icon fails to resolve even though it's present.
    // A pre-sized icon set directory forces it to ship all standard sizes.
    icon: "build/icons",
    // package.json's "name" is the scoped npm name "@store/desktop", which is
    // invalid as a WM_CLASS/app_id. syncDesktopName (paired with
    // package.json's "desktopName") makes the installed .desktop filename
    // match StartupWMClass and Electron's app_id, so desktop environments can
    // link the running window back to the installed .desktop entry —
    // otherwise launcher/search icons don't resolve even though the window's
    // own icon (taskbar) shows fine.
    syncDesktopName: true,
  },
}
