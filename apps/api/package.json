{
  "name": "@store/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --remote --port 8787",
    "deploy": "wrangler deploy",
    "typegen": "env -i HOME=\"$HOME\" PATH=\"$PATH\" wrangler types --env-file .env.types --env-interface CloudflareBindings",
    "check": "env -i HOME=\"$HOME\" PATH=\"$PATH\" wrangler types --env-file .env.types --env-interface CloudflareBindings --check && tsc --noEmit",
    "test": "vitest run --root ../.. apps/api/src",
    "build": "wrangler deploy --dry-run --outdir dist"
  },
  "dependencies": {
    "@effect/sql-pg": "4.0.0-beta.83",
    "@store/auth": "workspace:*",
    "@store/contracts": "workspace:*",
    "@store/db": "workspace:*",
    "drizzle-orm": "1.0.0-rc.4",
    "effect": "4.0.0-beta.83",
    "hono": "^4.12.29"
  },
  "devDependencies": {
    "@effect/vitest": "4.0.0-beta.83",
    "@types/node": "^24.13.3",
    "typescript": "^6.0.3",
    "vitest": "^4.0.18",
    "wrangler": "^4.110.0"
  }
}
