{
  "name": "store-electron",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "check": "turbo run check",
    "lint": "turbo run lint",
    "preview": "turbo run preview --parallel"
  },
  "devDependencies": {
    "turbo": "^2.6.0",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4",
    "vite-plus": "0.2.4"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "version": "1.3.14",
      "onFail": "download"
    }
  },
  "packageManager": "bun@1.3.14"
}
